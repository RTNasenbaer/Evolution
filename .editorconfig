# EditorConfig is awesome: https://EditorConfig.org
# Evolution Simulation Project - Editor Configuration

# Top-most EditorConfig file
root = true

# ==============================================================================
# Universal Settings
# ==============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# ==============================================================================
# Java Files
# ==============================================================================
[*.java]
indent_size = 4
max_line_length = 120
continuation_indent_size = 8

# ==============================================================================
# Python Files
# ==============================================================================
[*.py]
indent_size = 4
max_line_length = 100

# ==============================================================================
# Shell Scripts
# ==============================================================================
[*.sh]
indent_size = 4
end_of_line = lf

[*.bash]
indent_size = 4
end_of_line = lf

# ==============================================================================
# Windows Batch Files
# ==============================================================================
[*.{bat,cmd}]
indent_size = 4
end_of_line = crlf

# ==============================================================================
# PowerShell Scripts
# ==============================================================================
[*.ps1]
indent_size = 4
end_of_line = crlf

# ==============================================================================
# Markdown Documentation
# ==============================================================================
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 100

# ==============================================================================
# Configuration Files
# ==============================================================================
[*.{json,yml,yaml}]
indent_size = 2

[*.xml]
indent_size = 2

[*.properties]
indent_size = 4

# ==============================================================================
# Web Files (if applicable)
# ==============================================================================
[*.{html,css,js,jsx,ts,tsx}]
indent_size = 2

# ==============================================================================
# Makefiles
# ==============================================================================
[Makefile]
indent_style = tab

# ==============================================================================
# Special Files
# ==============================================================================
[*.seed]
indent_size = 2
insert_final_newline = false

[*.csv]
trim_trailing_whitespace = false
insert_final_newline = false

# ==============================================================================
# Jupyter Notebooks
# ==============================================================================
[*.ipynb]
indent_size = 2
